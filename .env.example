# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Django core ─────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,miningstockreport.com,www.miningstockreport.com

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (dev):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (prod):
# DATABASE_URL=postgres://user:password@localhost:5432/miningstockreport

# ── Site metadata ────────────────────────────────────────────────────────────
SITE_URL=https://miningstockreport.com
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@YourChannelHandle
TWITTER_URL=https://twitter.com/yourhandle

# ── Email ────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@miningstockreport.com
SERVER_EMAIL=noreply@miningstockreport.com

# SMTP (production) — e.g. SendGrid, Mailgun, SES
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# ── Mailchimp (optional) ─────────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# ── CORS (mobile app) ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Sentry (production error tracking) ──────────────────────────────────────
SENTRY_DSN=

# ── AWS S3 (optional — for media file storage in production) ────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-1
